{
  "name": "logseq-callout",
  "description": "Tag-driven callout styling for Logseq blocks — icons, labels, colored backgrounds with nested visual hierarchy",
  "version": "0.1.0",
  "author": "Danzu",
  "license": "MIT",
  "theme": false,
  "web": true,
  "supportsDB": true,
  "supportsDBOnly": true,
  "effect": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logseq/libs": "^0.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.2"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "^4.18.0",
      "picomatch": "^4.0.4",
      "postcss": "^8.5.10"
    }
  },
  "logseq": {
    "id": "logseq-danzu-callout",
    "title": "Callout Manager",
    "description": "Tag-driven callout styling — icons, labels, colored backgrounds with nested visual hierarchy",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  }
}
